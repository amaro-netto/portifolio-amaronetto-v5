---
import Layout from '../layouts/Layout.astro';

import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import AboutSection from '../components/AboutSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import ExperienceSection from '../components/ExperienceSection.astro';
import PortfolioSection from '../components/PortfolioSection.astro';
import ArticlesSection from '../components/ArticlesSection.astro';
import ContactSection from '../components/ContactSection.astro';
---

<Layout 
    title="Amaro Netto | Soluções em Tecnologia Boutique"
    description="Consultoria boutique em Tecnologia da Informação. Desenvolvimento de software sob medida, UX/UI Corporativo, Infraestrutura Cloud e Liderança Técnica."
>
    <div class="relative w-full">
        <a 
            href="#main-content" 
            class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 z-[110] bg-primary text-white px-6 py-3 rounded-sm font-bold font-sans tracking-widest uppercase shadow-xl"
        >
            Pular para o conteúdo principal
        </a>

        <Header />
        
        <main id="main-content" tabindex="-1" class="focus:outline-none flex flex-col w-full overflow-hidden">
            <HeroSection />
            <AboutSection />
            <ServicesSection />
            <ExperienceSection />
            <PortfolioSection />
            <ArticlesSection />
            <ContactSection />
        </main>
    </div>
</Layout>