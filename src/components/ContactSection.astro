---
import Footer from './Footer.astro';

const socialLinks = [
  { 
    label: 'WhatsApp', 
    url: 'https://wa.me/5521964039120',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`
  },
  { 
    label: 'LinkedIn', 
    url: 'https://linkedin.com/in/amarosilvanetto',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>`
  },
  { 
    label: 'GitHub', 
    url: 'https://github.com/amaro-netto',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`
  },
  { 
    label: 'Instagram', 
    url: 'https://instagram.com/ti.amaronetto',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>`
  }
];
---

<section id="contato" class="bg-background pt-24 border-t border-surface/30 scroll-mt-20 flex flex-col min-h-screen">
  
  <div class="container mx-auto px-4 flex-grow flex flex-col justify-center pb-20 max-w-6xl">
    
    <div class="text-center mb-16">
       <h2 class="font-serif text-3xl md:text-5xl font-bold text-foreground mb-6 uppercase tracking-tight">
         Vamos <span class="text-primary italic lowercase">Conversar?</span>
       </h2>
       <p class="text-foreground/70 text-lg font-sans max-w-2xl mx-auto leading-relaxed">
         Tem um desafio tecnológico em mente ou procura alinhar a sua infraestrutura com a estratégia de negócio? Envie uma mensagem.
       </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      
      <div class="lg:col-span-5 flex flex-col gap-10 order-2 lg:order-1">
        
        <div class="space-y-6">
            <div class="flex items-start gap-4 p-6 bg-surface/5 border border-surface/50 rounded-sm hover:border-primary/30 transition-colors">
                <div class="mt-1 w-10 h-10 flex items-center justify-center bg-surface/30 text-primary rounded-full shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </div>
                <div>
                    <h4 class="font-serif text-lg font-bold text-foreground">Email Direto</h4>
                    <a href="mailto:ti.amaronetto@gmail.com" class="font-sans text-foreground/70 hover:text-primary transition-colors">
                        ti.amaronetto@gmail.com
                    </a>
                </div>
            </div>

            <div class="flex items-start gap-4 p-6 bg-surface/5 border border-surface/50 rounded-sm hover:border-primary/30 transition-colors">
                <div class="mt-1 w-10 h-10 flex items-center justify-center bg-surface/30 text-primary rounded-full shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <div>
                    <h4 class="font-serif text-lg font-bold text-foreground">Horário de Atendimento</h4>
                    <p class="font-sans text-foreground/70">Seg - Sex: 09h às 18h</p>
                </div>
            </div>

            <div class="flex items-start gap-4 p-6 bg-surface/5 border border-surface/50 rounded-sm hover:border-primary/30 transition-colors">
                <div class="mt-1 w-10 h-10 flex items-center justify-center bg-surface/30 text-primary rounded-full shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <div>
                    <h4 class="font-serif text-lg font-bold text-foreground">Base de Operações</h4>
                    <p class="font-sans text-foreground/70">Rio de Janeiro, RJ (Atendimento Global)</p>
                </div>
            </div>
        </div>

        <div class="pt-6 border-t border-surface/40">
            <h3 class="font-sans text-xs uppercase tracking-widest text-foreground/50 font-bold mb-6">Conexões Profissionais</h3>
            <div class="flex flex-wrap gap-4">
                {socialLinks.map((social) => (
                <a
                    href={social.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-12 h-12 flex items-center justify-center rounded-full bg-background border border-surface hover:border-primary hover:bg-surface/30 text-foreground hover:text-primary transition-all duration-300"
                    title={social.label}
                    aria-label={`Ir para ${social.label}`}
                >
                    <Fragment set:html={social.icon} />
                </a>
                ))}
            </div>
        </div>

      </div>

      <div class="lg:col-span-7 order-1 lg:order-2">
        <div class="bg-surface/5 border border-surface/50 p-8 md:p-10 rounded-sm">
            
            <form action="mailto:ti.amaronetto@gmail.com" method="POST" enctype="text/plain" class="space-y-6">
                
                <div class="grid md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label for="nome" class="font-sans text-sm font-bold text-foreground/80 uppercase tracking-wider">Nome Completo</label>
                        <input 
                          type="text" 
                          id="nome" 
                          name="Nome" 
                          required 
                          class="w-full bg-background border border-surface/60 px-4 py-3 rounded-sm focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-sans text-foreground"
                          placeholder="Ex: João Silva"
                        />
                    </div>
                    <div class="space-y-2">
                        <label for="email" class="font-sans text-sm font-bold text-foreground/80 uppercase tracking-wider">E-mail Corporativo</label>
                        <input 
                          type="email" 
                          id="email" 
                          name="Email" 
                          required 
                          class="w-full bg-background border border-surface/60 px-4 py-3 rounded-sm focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-sans text-foreground"
                          placeholder="joao@empresa.com"
                        />
                    </div>
                </div>
                
                <div class="space-y-2">
                    <label for="assunto" class="font-sans text-sm font-bold text-foreground/80 uppercase tracking-wider">Assunto / Motivo do Contato</label>
                    <input 
                      type="text" 
                      id="assunto" 
                      name="Assunto" 
                      required 
                      class="w-full bg-background border border-surface/60 px-4 py-3 rounded-sm focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-sans text-foreground"
                      placeholder="Consultoria Cloud, Desenvolvimento Web, etc."
                    />
                </div>

                <div class="space-y-2">
                    <label for="mensagem" class="font-sans text-sm font-bold text-foreground/80 uppercase tracking-wider">Mensagem</label>
                    <textarea 
                        id="mensagem" 
                        name="Mensagem" 
                        required 
                        rows="5"
                        class="w-full bg-background border border-surface/60 px-4 py-3 rounded-sm focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-sans text-foreground resize-none" 
                        placeholder="Como posso ajudar a escalar o seu negócio?" 
                    ></textarea>
                </div>

                <button 
                    type="submit" 
                    class="w-full md:w-auto inline-flex items-center justify-center px-8 py-4 bg-primary text-white font-sans text-sm font-bold uppercase tracking-wider rounded-sm hover:bg-primary/90 transition-colors group"
                >
                    Enviar Mensagem
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-3 group-hover:translate-x-1 transition-transform"><line x1="22" x2="11" y1="2" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                </button>
            </form>

        </div>
      </div>

    </div>
  </div>
  
  <Footer />
</section>