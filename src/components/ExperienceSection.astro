---
import experiencesData from '../data/experiences.json';

// Lemos o seu JSON e ordenamos pela posição
const experiences = [...experiencesData].sort((a, b) => (Number(a.position) || 0) - (Number(b.position) || 0));
---

<section id="experiencia" class="bg-background scroll-mt-20 py-24 border-t border-surface/30">
  <div class="container mx-auto px-4 max-w-5xl">
    
    <div class="text-center mb-20">
      <h2 class="font-serif text-3xl md:text-5xl font-bold text-foreground mb-6 uppercase tracking-tight">
        Carreira & <span class="text-primary italic lowercase">Experiência</span>
      </h2>
      <p class="text-foreground/70 text-lg font-sans max-w-2xl mx-auto leading-relaxed">
        Uma trajetória profissional que combina desenvolvimento de software estruturado, liderança técnica e foco em resultados estratégicos.
      </p>
    </div>

    <div class="relative border-l border-surface/60 ml-3 md:ml-6 space-y-16 pb-8">
      
      {experiences.map((exp) => (
        <div class="relative pl-8 md:pl-16 group">
          
          <div class="absolute w-4 h-4 rounded-full bg-background border-[3px] border-surface left-[-8.5px] top-1.5 group-hover:border-primary group-hover:scale-125 transition-all duration-300"></div>
          
          <div class="flex flex-col md:flex-row md:items-baseline justify-between mb-3 gap-2 md:gap-8">
            <h3 class="font-serif text-2xl md:text-3xl font-bold text-foreground group-hover:text-primary transition-colors">
              {exp.role}
            </h3>
            <div class="flex items-center gap-2 text-primary font-sans text-sm md:text-base font-bold uppercase tracking-wider shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              {exp.years}
            </div>
          </div>

          <div class="flex items-center gap-2 text-foreground/60 mb-6 font-sans text-sm md:text-base uppercase tracking-widest font-bold">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10h16"/><path d="M4 14h16"/><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2z"/><path d="M9 22v-8"/><path d="M15 22v-8"/></svg>
            {exp.company}
          </div>

          <p class="text-foreground/80 leading-relaxed font-sans text-justify mb-6 md:text-lg">
            {exp.description}
          </p>

          {exp.achievements && exp.achievements.length > 0 && (
            <div class="mb-8 p-6 bg-surface/10 border border-surface/30 rounded-sm">
              <h4 class="font-sans text-xs uppercase tracking-widest text-foreground/50 font-bold mb-4">Principais Conquistas</h4>
              <ul class="space-y-3">
                {exp.achievements.map((achievement: string) => (
                  <li class="flex items-start gap-3 text-foreground/80 font-sans text-sm md:text-base">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary shrink-0"></span>
                    <span class="leading-relaxed">{achievement}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {exp.technologies && exp.technologies.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {exp.technologies.map((tech: string) => (
                <span class="font-sans text-xs font-bold text-foreground/60 bg-transparent border border-surface/60 px-3 py-1.5 rounded-sm hover:text-primary hover:border-primary/40 transition-colors cursor-default">
                  {tech}
                </span>
              ))}
            </div>
          )}
          
        </div>
      ))}
      
    </div>
  </div>
</section>