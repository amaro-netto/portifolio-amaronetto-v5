---
import amaroPortrait from '../assets/amaro-portrait.webp';

const certifications = [
  { 
    id: 'redes', 
    label: 'Redes', 
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="16" y="16" width="6" height="6" rx="1"/><rect x="2" y="16" width="6" height="6" rx="1"/><rect x="9" y="2" width="6" height="6" rx="1"/><path d="M5 16v-3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3"/><path d="M12 12V8"/></svg>' 
  },
  { 
    id: 'projetos', 
    label: 'Projetos', 
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>' 
  },
  { 
    id: 'suporte', 
    label: 'Suporte', 
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2-1 4-2 7-2 2.5 0 4.5 1 6.5 2a1 1 0 0 1 1 1z"/></svg>' 
  },
  { 
    id: 'design', 
    label: 'Design', 
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>' 
  },
];
---

<section 
  id="inicio" 
  class="relative bg-background overflow-hidden min-h-screen flex flex-col pt-20 lg:pt-0"
  aria-label="Introdução e Boas-vindas"
>
  
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-surface/40 via-background to-background pointer-events-none select-none"></div>
  
  <div class="relative container mx-auto px-4 flex-grow flex flex-col lg:flex-row items-center z-10 h-full">
    
    <div class="flex-1 flex flex-col justify-center items-center lg:items-start text-center lg:text-left z-20 lg:w-1/2 py-12 lg:py-0">
      <div class="space-y-8 max-w-2xl">
        
        <div class="space-y-4">
          <p class="text-sm md:text-base font-bold tracking-[0.2em] text-primary/80 uppercase">
            Profissional de TI & Designer
          </p>
          
          <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl leading-[1.1] text-foreground drop-shadow-sm">
            Soluções em <br />
            <span class="text-primary italic">Tecnologia</span> <br />
            para seu Negócio
          </h1>
          
          <p class="text-base sm:text-lg text-foreground/70 max-w-xl mx-auto lg:mx-0 leading-relaxed pt-4">
            Transformo desafios complexos em soluções digitais eficientes. 
            Uma abordagem boutique que une infraestrutura robusta, código limpo e design focado em resultados.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 w-full max-w-md mx-auto lg:mx-0 pt-2">
          <a
            href="#portfolio"
            class="flex-1 inline-flex items-center justify-center px-6 py-3.5 bg-primary text-white font-medium text-sm md:text-base rounded-md hover:bg-primary/90 transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5 group"
            aria-label="Ver meu portfólio"
          >
            Ver Portfólio
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2 transition-transform group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          
          <a
            href="#contato"
            class="flex-1 inline-flex items-center justify-center px-6 py-3.5 border-2 border-primary text-primary font-medium text-sm md:text-base rounded-md hover:bg-primary hover:text-white transition-all duration-300 hover:-translate-y-0.5"
            aria-label="Entrar em contato"
          >
            Contate-me
          </a>
        </div>

        <div class="flex flex-wrap gap-6 justify-center lg:justify-start pt-8 border-t border-surface/50 w-full max-w-lg mx-auto lg:mx-0 mt-8">
          {certifications.map((cert) => (
            <div class="group relative flex flex-col items-center gap-2">
              <div class="w-12 h-12 flex items-center justify-center rounded-full bg-surface/30 text-primary border border-transparent group-hover:border-primary/20 group-hover:bg-surface/50 transition-all duration-300">
                <Fragment set:html={cert.svg} />
              </div>
              <span class="text-xs font-bold tracking-wider uppercase text-foreground/60 group-hover:text-primary transition-colors">
                {cert.label}
              </span>
            </div>
          ))}
        </div>

      </div>
    </div>

    <div class="flex-1 w-full flex justify-center lg:justify-end items-end h-[400px] lg:h-screen lg:absolute lg:right-0 lg:bottom-0 lg:w-1/2 pointer-events-none mt-12 lg:mt-0">
        <div class="relative w-full h-full flex justify-center lg:justify-end items-end">
          <div class="absolute bottom-0 w-3/4 h-3/4 bg-surface/50 blur-[100px] rounded-full pointer-events-none"></div>
          
          <img
            src={amaroPortrait.src}
            alt="Amaro Netto - Profissional de TI"
            width={amaroPortrait.width}
            height={amaroPortrait.height}
            class="relative z-10 w-auto object-contain object-bottom h-[110%] max-h-[500px] lg:h-[90vh] lg:max-h-none lg:mr-10 drop-shadow-2xl"
            loading="eager"
            fetchpriority="high"
          />
        </div>
    </div>

  </div>
</section>